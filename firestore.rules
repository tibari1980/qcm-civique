rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user has 'admin' role (safely check existence)
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if user email is in the admin whitelist
    function isWhitelisted() {
      return isAuthenticated() && 
        (request.auth.token.email == 'tibarinewdzign@gmail.com' || request.auth.token.email == 'admin@civiq.fr');
    }

    // Check if a specific field is being modified
    function isFieldUnchanged(fieldName) {
      return !(fieldName in request.resource.data) || 
        (resource != null && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      // Allow read if owner or admin
      // FALLBACK: Allow read if owner even if profile doesn't exist yet (for creation)
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow create: only owner can create their profile
      // If whitelisted, can start as admin or user. Otherwise, must be user.
      allow create: if isOwner(userId) && (
        request.resource.data.role == 'user' || (isWhitelisted() && request.resource.data.role == 'admin')
      );
      
      // Allow update: 
      // - Admin can update everything
      // - Owner can update everything EXCEPT their role (unless they are whitelisted and becoming admin)
      allow update: if isAdmin() || (isOwner(userId) && (
        isFieldUnchanged('role') || (isWhitelisted() && request.resource.data.role == 'admin')
      ));
      
      // Delete: only admins
      allow delete: if isAdmin();
    }

    // Questions Collection
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Attempts Collection
    match /attempts/{attemptId} {
      // Must be authenticated and user_id must match auth.uid
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // Read if owner or admin
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      // Only admins can update/delete attempts
      allow update, delete: if isAdmin();
    }

    // Config Collection
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      // Public read if approved
      // Admin can see everything
      // Owner can see their review
      allow get: if resource.data.isApproved == true || isOwner(resource.data.userId) || isAdmin();
      allow list: if resource.data.isApproved == true || isAdmin() || isOwner(resource.data.userId);
      
      // Create: Authenticated users can create their own review, initially non-approved
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isApproved == false;
      
      // Update: Admin can approve, Owner can edit comment/rating but not approval
      allow update: if isAdmin() || (isOwner(resource.data.userId) && isFieldUnchanged('isApproved'));
      
      // Delete: Only admins or owners
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Owner can read and update (status)
      allow read, update: if isOwner(resource.data.userId);
      // Admin can do everything
      allow write: if isAdmin();
    }

    // Default: Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
